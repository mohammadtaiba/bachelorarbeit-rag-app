# .env

## Lokale Ollama-Verbindung
OLLAMA_URL=http://localhost:11434

## Modelle
### Embedding:
EMBED_MODEL=nomic-embed-text
### Textgenerierung
# LLM_MODEL=llama3              # sehr schlecht
# LLM_MODEL=llama3:70b          # braucht viel RAM: > 32 GiB
# LLM_MODEL=llama3:8b           # sehr schlecht auch
LLM_MODEL=gpt-oss:120b-cloud

## DB / Datenbank
COLLECTION=bachelorarbeit
DB_PATH=./db/chromadb

## Dokumentenpfade
DATA_RAW=./data/raw
DATA_UPLOAD=./data/upload
DATA_TEMP_MD=./data/temp_markdown
DATA_MARKDOWN=./data/markdown


# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=75