# .env

## Lokale Ollama-Verbindung
OLLAMA_URL=http://localhost:11434

## Modelle
### Embedding:
EMBED_MODEL=nomic-embed-text
### Textgenerierung
# LLM_MODEL=llama3              # sehr schlecht
# LLM_MODEL=llama3:70b          # braucht viel RAM: > 32 GiB
# LLM_MODEL=llama3:8b           # sehr schlecht auch
LLM_MODEL=gpt-oss:120b-cloud

## DB / Datenbank
COLLECTION=bachelorarbeit
PATH_DB=./db/chromadb

## Dokumentenpfade
PATH_RAW=./data/raw
PATH_UPLOAD=./data/upload
PATH_PROCESSING=./data/processing
PATH_PROCESSED=./data/processed