        <link:link rdf:resource="#item_85"/>
        <link:link rdf:resource="#item_86"/>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Artificial Intelligence</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>Chatbots</rdf:value></z:AutomaticTag>
